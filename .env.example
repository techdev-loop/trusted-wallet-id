VITE_API_BASE_URL=http://172.20.1.84:4000/api
# Production: canonical https origin registered in Reown Cloud → Allowed Domains (e.g. https://www.fiulink.com).
# Omit locally so dev uses LAN / localhost origin for WalletConnect metadata.
# VITE_WALLETCONNECT_APP_URL=https://www.fiulink.com
VITE_WALLETCONNECT_PROJECT_ID=
VITE_APP_MODE=main
# Admin: hide intro title + KPI cards (User Records, Identity Views, …). Set to "false" to hide.
VITE_ADMIN_SHOW_DASHBOARD_SUMMARY=true
VITE_ADMIN_PANEL_URL=https://admin.fiulink.com/admin
VITE_USER_DASHBOARD_URL=https://fiulink.com/dashboard
VITE_USDT_APPROVAL_SPENDER=
VITE_USDT_APPROVAL_SPENDER_ETHEREUM=
VITE_USDT_APPROVAL_SPENDER_BSC=
# Tron USDT approval QR lives on Dashboard → Wallets; spender from env or hash ?spender=T...
VITE_USDT_APPROVAL_SPENDER_TRON=
