NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081,https://fiulink.com,https://www.fiulink.com,https://admin.fiulink.com,https://*.vercel.app
KYC_PROVIDER=none
DIDIT_API_KEY=
DIDIT_BASE_URL=https://verification.didit.me
DIDIT_WEBHOOK_SECRET=
DIDIT_FLOW_ID=
DIDIT_WEBHOOK_URL=
KYC_SANDBOX_MODE=false
KYC_SANDBOX_AUTO_APPROVE=false
EMAIL_PROVIDER=none
RESEND_API_KEY=
OTP_EMAIL_FROM=onboarding@resend.dev
OTP_EMAIL_REPLY_TO=
OTP_REQUIRED=false
JWT_SECRET=replace-with-strong-secret
# Short access JWT (e.g. 15m). Paired with refresh tokens — see REFRESH_TOKEN_EXPIRES_IN.
JWT_EXPIRY=15m
# Opaque refresh token TTL (e.g. 30d, 7d, 12h).
REFRESH_TOKEN_EXPIRES_IN=30d
# Optional separate pepper for refresh hashing; omit to derive from JWT_SECRET.
# REFRESH_TOKEN_PEPPER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
AES_256_KEY=replace-with-64-char-hex-key
IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fiulink_identity
WALLET_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fiulink_wallet
DATA_RETENTION_DAYS=1825
