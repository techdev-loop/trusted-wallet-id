{
  "name": "fiulink-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:init": "tsx src/scripts/init-db.ts",
    "db:migrate": "tsx src/scripts/init-db.ts",
    "admin:bootstrap": "tsx src/scripts/bootstrap-admin.ts",
    "admin:demote": "tsx src/scripts/demote-admin.ts",
    "admin:set-role": "tsx src/scripts/set-role.ts",
    "contracts:init": "tsx src/scripts/init-contract-configs.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tronweb3/walletconnect-tron": "^4.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ethers": "^6.15.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "resend": "^4.7.0",
    "tronweb": "^6.2.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
