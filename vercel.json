{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "framework": "vite",
      "entrypoint": ".",
      "routePrefix": "/"
    },
    "backend": {
      "framework": "express",
      "entrypoint": "backend",
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
